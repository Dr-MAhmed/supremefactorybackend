{
  "framework": null,
  "buildCommand": "npx prisma generate && npx tsc",
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "src/api/index.ts",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/api/index.ts"
    }
  ]
}